# --- [ 5. دالة استخراج التوكن - TOKEN EXTRACTOR ] ---
# دالة تقنية "مشبعة" لاستخراج توكن العمل من الكوكيز لضمان عمل الـ API
def extract_token(cookie):
    try:
        # محاولة الحصول على توكن Business Suite
        req = requests.get("https://business.facebook.com/business_locations", 
                           headers={"user-agent": "Mozilla/5.0", "cookie": cookie}).text
        token = re.search('(EAAG\w+)', req).group(1)
        return token
    except:
        # في حال الفشل نستخدم توكن عام (قد لا يدعم كل الميزات)
        return "EAAGNO4aepSABAN..." 

