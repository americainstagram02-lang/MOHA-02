            return func(*args, **kwargs)
        except requests.exceptions.SSLError:
            print(f"\n {R}[!] SSL ERROR: CHECK YOUR INTERNET OR DATE/TIME.")
        except requests.exceptions.ConnectionError:
            print(f"\n {R}[!] CONNECTION LOST: RETRYING IN 5 SECONDS...")
            time.sleep(5)
        except KeyboardInterrupt:
            print(f"\n {Y}[!] PROCESS INTERRUPTED BY USER.")
            sys.exit()
        except Exception as e:
            # تسجيل الخطأ في ملف لسهولة الإصلاح لاحقاً
            with open('/sdcard/moha_error_log.txt', 'a') as log:
                log.write(f"Error: {str(e)}\n")
            pass
    return wrapper

